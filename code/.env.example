# Content Triage Agent – environment variables
# Copy to .env and set values. Do NOT commit .env or secrets to version control.
# In production, use a secret manager or env injection for sensitive values.

# Database
DATABASE_URL=sqlite:///./classifier.db

# LLM (litellm) – when using custom provider (e.g. OpenAI-compatible)
LITELLM_MODEL=gpt-4o-mini
LITELLM_API_KEY=
LITELLM_API_BASE=
CUSTOM_LLM_PROVIDER=openai
LITELLM_TEMPERATURE=0
LITELLM_API_VERSION=

# Logging and environment
LOG_LEVEL=INFO
ENVIRONMENT=dev

# Rate limiting (per IP for POST /submissions)
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Submission validation
SUBMISSION_MAX_LENGTH=10000

# Optional: team API base URLs (for routing stubs)
# TEAM_ENGINEERING_URL=
# TEAM_CUSTOMER_SUPPORT_URL=
# TEAM_PRODUCT_MANAGEMENT_URL=
# TEAM_FEEDBACK_URL=
# TEAM_ESCALATION_URL=
# TEAM_LOCALIZATION_URL=
# TEAM_DISCARD_URL=
